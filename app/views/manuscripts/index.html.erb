<% content_for :title, "原稿一覧 | FAX原稿AI" %>

<div class="app-shell">
  <%= render "shared/sidebar", active: :manuscripts %>

  <main class="main-area">
    <%= render "shared/topbar" %>
    <%= render "shared/flash" %>

    <section class="page-heading">
      <div>
        <h1>原稿一覧</h1>
        <p>作成したFAX原稿を一覧で確認・管理できます。</p>
      </div>
      <div class="heading-actions">
        <%= link_to "絞り込みをクリア", manuscripts_path, class: "secondary-button" %>
        <%= link_to "＋ 新規作成", new_manuscript_path, class: "primary-button" %>
      </div>
    </section>

    <%= form_with url: manuscripts_path, method: :get, class: "filter-bar" do |form| %>
      <%= form.search_field :q, value: params[:q], placeholder: "原稿タイトル・サービス名・ターゲットで検索" %>
      <%= form.select :status, [["ステータス：すべて", ""], ["完成", "generated"], ["レビュー中", "reviewing"], ["下書き", "draft"]], selected: params[:status] %>
      <%= form.submit "検索", class: "secondary-button" %>
    <% end %>

    <section class="table-card">
      <div class="table-row table-head">
        <span>原稿タイトル</span>
        <span>サービス名</span>
        <span>ターゲット</span>
        <span>ステータス</span>
        <span>更新日</span>
        <span>操作</span>
      </div>

      <% @manuscripts.each do |manuscript| %>
        <article class="table-row manuscript-row">
          <div>
            <strong><%= manuscript.title %></strong>
            <small><%= truncate(manuscript.service_summary, length: 42) %></small>
          </div>
          <span><%= manuscript.service_name %></span>
          <span><%= manuscript.target %></span>
          <span><mark class="status-badge <%= status_badge_class(manuscript.status) %>"><%= manuscript.status_label %></mark></span>
          <span><%= l(manuscript.updated_at, format: :short) %></span>
          <div class="row-actions">
            <%= link_to "詳細", manuscript_path(manuscript), class: "icon-button" %>
            <%= button_to "複製", duplicate_manuscript_path(manuscript), method: :post, class: "icon-button" %>
            <%= button_to "削除", manuscript_path(manuscript), method: :delete, class: "danger-button" %>
          </div>
        </article>
      <% end %>

      <% if @manuscripts.empty? %>
        <div class="empty-state">
          <h2>まだ原稿がありません</h2>
          <p>新規作成から、最初のFAXDM原稿を作成してください。</p>
          <%= link_to "新規作成へ", new_manuscript_path, class: "primary-button" %>
        </div>
      <% end %>
    </section>

    <div class="list-footer">
      <span>全 <%= @manuscripts.size %> 件を表示</span>
      <%= link_to "テンプレート一覧を見る", templates_path, class: "text-link" %>
    </div>
  </main>
</div>
